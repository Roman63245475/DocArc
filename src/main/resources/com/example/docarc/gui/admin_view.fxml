<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="960.0" stylesheets="@css/admin-styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.docarc.gui.AdminController">
    <children>
        <VBox fx:id="sideBar" managed="false" maxWidth="1.7976931348623157E308" minWidth="0.0" prefHeight="600.0" prefWidth="0.0" styleClass="sidebar" visible="false">
            <children>
                <VBox styleClass="sidebar-brand">
                    <children>
                        <Label fx:id="adminNameLabel" styleClass="sidebar-admin-name" text="Admin User" />
                        <Label styleClass="sidebar-admin-role" text="Admin" />
                    </children>
                </VBox>
                <HBox alignment="CENTER_LEFT" minHeight="36.0" minWidth="0.0" prefWidth="192.0" spacing="10.0" styleClass="nav-item nav-item-active">
                    <children>
                        <Button fx:id="userManBtn" maxWidth="Infinity" minWidth="0.0" mnemonicParsing="false" nodeOrientation="LEFT_TO_RIGHT" onAction="#onUserManClick" styleClass="nav-btn" text="User Management" HBox.hgrow="ALWAYS">
                     <graphic>
                              <Region id="users-icon" maxHeight="20.0" maxWidth="20.0" minHeight="16.0" minWidth="16.0" prefHeight="16.0" prefWidth="16.0" styleClass="nav-icon" />
                     </graphic></Button>
                    </children>
                    <padding><Insets left="20.0" /></padding>
                </HBox>
                <HBox alignment="CENTER_LEFT" minHeight="36.0" minWidth="0.0" prefWidth="192.0" spacing="10.0" styleClass="nav-item">
                    <children>
                        <Button fx:id="profileManagementButton" maxWidth="Infinity" minWidth="0.0" mnemonicParsing="false" onAction="#profileManagementButtonClick" styleClass="nav-btn" text="Profile Management" HBox.hgrow="ALWAYS">
                     <graphic>
                              <Region id="metadata-icon" maxHeight="20.0" maxWidth="20.0" minHeight="16.0" minWidth="16.0" prefHeight="16.0" prefWidth="16.0" styleClass="nav-icon" />
                     </graphic></Button>
                    </children>
                    <padding><Insets left="20.0" /></padding>
                </HBox>
                <HBox alignment="CENTER_LEFT" minHeight="36.0" minWidth="0.0" prefWidth="192.0" spacing="10.0" styleClass="nav-item">
                    <children>
                        <Button fx:id="ActivityLogBtn" maxWidth="Infinity" minWidth="0.0" mnemonicParsing="false" onAction="#onLogsClick" styleClass="nav-btn" text="Activity log" HBox.hgrow="ALWAYS">
                     <graphic>
                              <Region id="logs-icon" maxHeight="20.0" maxWidth="20.0" minHeight="16.0" minWidth="16.0" prefHeight="16.0" prefWidth="16.0" styleClass="nav-icon" />
                     </graphic></Button>
                    </children>
                    <padding><Insets left="20.0" /></padding>
                </HBox>
            <HBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="158.0" minHeight="36.0" minWidth="0.0" prefWidth="192.0" spacing="10.0" styleClass="nav-item">
               <children>
                  <Button maxWidth="Infinity" minWidth="0.0" mnemonicParsing="false" onAction="#onClientManagementClick" styleClass="nav-btn" text="Clients Management" HBox.hgrow="ALWAYS">
                     <graphic>
                        <Region id="logs-icon" maxHeight="20.0" maxWidth="20.0" minHeight="16.0" minWidth="16.0" prefHeight="16.0" prefWidth="16.0" styleClass="nav-icon" />
                     </graphic>
                  </Button>
               </children>
               <padding>
                  <Insets left="20.0" />
               </padding>
            </HBox>
                <Region prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
            <Region id="question-icon" fx:id="questionIcon" maxHeight="-Infinity" maxWidth="-Infinity" onMouseClicked="#openShortcuts" prefHeight="20.0" prefWidth="20.0" styleClass="gray-bg" />
            </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
        </VBox>
        <VBox prefHeight="600.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT" minHeight="51.0" spacing="12.0" styleClass="topbar">
                    <children>
                        <Region fx:id="menuSlideBtn" maxHeight="-Infinity" onMouseClicked="#menuSlide" prefHeight="22.0" prefWidth="22.0" styleClass="menu-icon">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Region>
                        <ImageView fitHeight="28.0" fitWidth="154.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/LogoGreen2H.png" />
                            </image>
                        </ImageView>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="welcomeUserLabel" styleClass="topbar-admin-name" text="Admin User" />
                  <Button fx:id="logOutButton" mnemonicParsing="false" onAction="#logOut" text="Log out">
                     <styleClass>
                        <String fx:value="topbar-admin-name" />
                        <String fx:value="logout-btn" />
                     </styleClass></Button>
                    </children>
                    <padding><Insets bottom="12.0" left="24.0" right="24.0" top="12.0" /></padding>
                </HBox>
                <StackPane fx:id="contentBox" prefHeight="600.0" prefWidth="768.0" styleClass="content-area" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox fx:id="userManagementBox" alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="15.0" visible="false">
                            <children>
                                <HBox alignment="CENTER_LEFT" prefWidth="200.0">
                                    <children>
                                        <Label styleClass="panel-title" text="User Management" />
                                        <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                                        <Button fx:id="addUserButton" mnemonicParsing="false" onAction="#onAddUser" styleClass="btn-primary" text="+ Add User" />
                                    </children>
                                </HBox>
                        <ComboBox fx:id="clientsComboBox" prefHeight="25.0" prefWidth="281.0" promptText="Select a client whos users you want to see" styleClass="field" />
                                <TableView fx:id="usersTable" prefHeight="265.0" prefWidth="760.0" styleClass="table-view" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="userUsernameColumn" prefWidth="75.0" text="USERNAME" />
                                        <TableColumn fx:id="userRoleColumn" prefWidth="75.0" text="ROLE" />
                              <TableColumn fx:id="actionsColumn" prefWidth="75.0" text="ACTIONS" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                  <VBox fx:id="activityLogsBox" alignment="TOP_CENTER" layoutX="30.0" layoutY="30.0" prefHeight="200.0" prefWidth="100.0" spacing="15.0">
                     <children>
                        <HBox alignment="CENTER_LEFT" prefWidth="200.0">
                           <children>
                              <Label styleClass="panel-title" text="Activity Log" />
                              <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="10.0">
                           <children>
                              <Label fx:id="logsLabel" minHeight="-Infinity" minWidth="-Infinity" styleClass="h2" text="App Logs" />
                              <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                              <HBox alignment="CENTER" prefHeight="30.0" prefWidth="344.0" spacing="10.0" styleClass="field">
                                 <children>
                                    <Region id="search-icon" maxHeight="-Infinity" prefHeight="15.0" prefWidth="15.0" styleClass="gray-bg" />
                                    <TextField fx:id="searchInput" styleClass="hide" HBox.hgrow="ALWAYS" />
                                 </children>
                                 <padding>
                                    <Insets left="10.0" right="10.0" />
                                 </padding>
                              </HBox>
                              <Button fx:id="appLogsBtn" disable="true" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#onAppLogsClick" styleClass="btn-primary" text="App Logs" />
                              <Button fx:id="errorLogsBtn" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#onErrorLogsClick" styleClass="btn-primary" text="Error Logs" />
                           </children>
                        </HBox>
                        <HBox prefHeight="100.0" prefWidth="200.0" spacing="15.0" VBox.vgrow="ALWAYS">
                           <children>
                              <StackPane fx:id="listContainer" prefHeight="150.0" prefWidth="200.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <ListView fx:id="appLogsList" prefHeight="200.0" prefWidth="200.0" />
                                    <ListView fx:id="errorLogsList" layoutX="10.0" layoutY="10.0" prefHeight="200.0" prefWidth="200.0" visible="false" />
                                 </children>
                              </StackPane>
                           </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="12.0" />
                     </children>
                  </VBox>
                  <VBox fx:id="profileManagementView" alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="15.0" visible="false">
                     <children>
                        <HBox alignment="CENTER_LEFT" prefWidth="200.0">
                           <children>
                              <Label styleClass="h1" text="Profiles" />
                           </children>
                        </HBox>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#createProfile" styleClass="btn-primary" text="Create new Profile" />
                              <Button fx:id="assignProfileToClientBtn" mnemonicParsing="false" onAction="#assignProfileToClientClick" styleClass="btn-primary" text="Assign to a client" />
                           </children>
                        </HBox>
                        <TableView fx:id="profilesTable" prefHeight="339.0" prefWidth="920.0" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="profileNameColumn" prefWidth="176.79998397827148" text="Name" />
                              <TableColumn fx:id="brightnessProfileColumn" prefWidth="193.59991455078125" text="Brightness" />
                              <TableColumn fx:id="contrastProfileColumn" prefWidth="243.199951171875" text="Contrast" />
                              <TableColumn fx:id="grayscaleProfileColumn" prefWidth="137.60003662109375" text="Grayscale" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>
                  <VBox fx:id="clientManagementView" alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0" visible="false">
                     <children>
                        <HBox prefWidth="200.0">
                           <children>
                              <Label styleClass="h1" text="Clients Management">
                                 <font>
                                    <Font size="14.0" />
                                 </font>
                              </Label>
                           </children>
                        </HBox>
                        <HBox alignment="CENTER_RIGHT" prefWidth="200.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#createClient" styleClass="btn-primary" text="+ Add Client" />
                           </children>
                        </HBox>
                        <TableView fx:id="clientsTable" prefHeight="284.0" prefWidth="920.0" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="clientNameColumn" prefWidth="177.0" text="Name" />
                              <TableColumn fx:id="clientCountryColumn" minWidth="0.0" prefWidth="253.0" text="Country" />
                              <TableColumn fx:id="clientCityColumn" prefWidth="226.0" text="City" />
                              <TableColumn fx:id="clientUserAmountColumn" prefWidth="263.0" text="Amount of employees" />
                          </columns>
                           <VBox.margin>
                              <Insets />
                           </VBox.margin>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>
                    </children>
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                </StackPane>
            </children>
        </VBox>
    </children>
</HBox>
