<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<HBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="960.0" stylesheets="@css/admin-styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.docarc.gui.AdminController">
    <children>
        <VBox fx:id="sideBar" managed="false" maxWidth="1.7976931348623157E308" minWidth="0.0" prefHeight="600.0" prefWidth="0.0" styleClass="sidebar" visible="false">
            <children>
                <VBox styleClass="sidebar-brand">
                    <children>
                        <Label fx:id="adminNameLabel" styleClass="sidebar-admin-name" text="Admin User" />
                        <Label styleClass="sidebar-admin-role" text="Admin" />
                    </children>
                </VBox>
                <HBox alignment="CENTER_LEFT" minHeight="36.0" minWidth="0.0" prefWidth="192.0" spacing="10.0" styleClass="nav-item nav-item-active">
                    <children>
                        <Button fx:id="userManBtn" maxWidth="Infinity" minWidth="0.0" mnemonicParsing="false" nodeOrientation="LEFT_TO_RIGHT" onAction="#onUserManClick" styleClass="nav-btn" text="User Management" HBox.hgrow="ALWAYS">
                     <graphic>
                              <Region id="users-icon" maxHeight="20.0" maxWidth="20.0" minHeight="16.0" minWidth="16.0" prefHeight="16.0" prefWidth="16.0" styleClass="nav-icon" />
                     </graphic></Button>
                    </children>
                    <padding><Insets left="20.0" /></padding>
                </HBox>
                <HBox alignment="CENTER_LEFT" minHeight="36.0" minWidth="0.0" prefWidth="192.0" spacing="10.0" styleClass="nav-item">
                    <children>
                        <Button fx:id="metadataBtn" maxWidth="Infinity" minWidth="0.0" mnemonicParsing="false" onAction="#onMetadataClick" styleClass="nav-btn" text="Metadata" HBox.hgrow="ALWAYS">
                     <graphic>
                              <Region id="metadata-icon" maxHeight="20.0" maxWidth="20.0" minHeight="16.0" minWidth="16.0" prefHeight="16.0" prefWidth="16.0" styleClass="nav-icon" />
                     </graphic></Button>
                    </children>
                    <padding><Insets left="20.0" /></padding>
                </HBox>
                <HBox alignment="CENTER_LEFT" minHeight="36.0" minWidth="0.0" prefWidth="192.0" spacing="10.0" styleClass="nav-item">
                    <children>
                        <Button fx:id="ActivityLogBtn" maxWidth="Infinity" minWidth="0.0" mnemonicParsing="false" onAction="#onLogsClick" styleClass="nav-btn" text="Activity log" HBox.hgrow="ALWAYS">
                     <graphic>
                              <Region id="logs-icon" maxHeight="20.0" maxWidth="20.0" minHeight="16.0" minWidth="16.0" prefHeight="16.0" prefWidth="16.0" styleClass="nav-icon" />
                     </graphic></Button>
                    </children>
                    <padding><Insets left="20.0" /></padding>
                </HBox>
                <Region prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
            </children>
        </VBox>
        <VBox prefHeight="600.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT" minHeight="51.0" spacing="12.0" styleClass="topbar">
                    <children>
                        <Region fx:id="menuSlideBtn" maxHeight="-Infinity" onMouseClicked="#menuSlide" prefHeight="22.0" prefWidth="22.0" styleClass="menu-icon">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Region>
                        <ImageView fitHeight="28.0" fitWidth="154.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/LogoGreen2H.png" />
                            </image>
                        </ImageView>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="welcomeUserLabel" styleClass="topbar-admin-name" text="Admin User" />
                    </children>
                    <padding><Insets bottom="12.0" left="24.0" right="24.0" top="12.0" /></padding>
                </HBox>
                <StackPane fx:id="contentBox" prefHeight="600.0" prefWidth="768.0" styleClass="content-area" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox fx:id="userManagementBox" alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="15.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" prefWidth="200.0">
                                    <children>
                                        <Label styleClass="panel-title" text="User Management" />
                                        <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                                        <Button fx:id="addUserButton" mnemonicParsing="false" onAction="#onAddUser" styleClass="btn-primary" text="+ Add User" />
                                    </children>
                                </HBox>
                                <TableView fx:id="usersTable" prefHeight="265.0" prefWidth="760.0" styleClass="table-view" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="userUsernameColumn" prefWidth="75.0" text="USERNAME" />
                                        <TableColumn fx:id="userRoleColumn" prefWidth="75.0" text="ROLE" />
                              <TableColumn fx:id="actionsColumn" prefWidth="75.0" text="ACTIONS" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                  <VBox fx:id="activityLogsBox" alignment="TOP_CENTER" layoutX="30.0" layoutY="30.0" prefHeight="200.0" prefWidth="100.0" spacing="15.0" visible="false">
                     <children>
                        <HBox alignment="CENTER_LEFT" prefWidth="200.0">
                           <children>
                              <Label styleClass="panel-title" text="Activity Log" />
                              <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="10.0">
                           <children>
                              <Label fx:id="logsLabel" styleClass="h2" text="App Logs" />
                              <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                              <Button fx:id="appLogsBtn" disable="true" mnemonicParsing="false" onAction="#onAppLogsClick" styleClass="btn-primary" text="App Logs" />
                              <Button fx:id="errorLogsBtn" mnemonicParsing="false" onAction="#onErrorLogsClick" styleClass="btn-primary" text="Error Logs" />
                           </children>
                        </HBox>
                        <HBox prefHeight="100.0" prefWidth="200.0" spacing="15.0" VBox.vgrow="ALWAYS">
                           <children>
                              <StackPane fx:id="listContainer" prefHeight="150.0" prefWidth="200.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <ListView fx:id="appLogsList" prefHeight="200.0" prefWidth="200.0" />
                                    <ListView fx:id="errorLogsList" layoutX="10.0" layoutY="10.0" prefHeight="200.0" prefWidth="200.0" visible="false" />
                                 </children>
                              </StackPane>
                           </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="12.0" />
                     </children>
                  </VBox>
                    </children>
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                </StackPane>
            </children>
        </VBox>
    </children>
</HBox>
