<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="360.0" prefWidth="427.0" spacing="12.0" stylesheets="@css/user-styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.docarc.gui.AssignProfileToClientController">
   <children>
      <Label minWidth="-Infinity" styleClass="h1" text="Assign profile" />
      <Label minWidth="-Infinity" text="Users who can receive this profile (regular users without this profile yet):" wrapText="true" />
      <ListView fx:id="eligibleClientsList" prefHeight="200.0" prefWidth="320.0" VBox.vgrow="ALWAYS" />
      <Label fx:id="errorLabel" managed="false" text="Error" visible="false" wrapText="true" />
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button fx:id="assignButton" minWidth="-Infinity" mnemonicParsing="false" onAction="#onAssign" prefHeight="28.0" prefWidth="55.0" text="Assign" />
            <Button minWidth="-Infinity" mnemonicParsing="false" onAction="#onCancel" prefHeight="28.0" prefWidth="53.0" text="Cancel" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
   </padding>
</VBox>
