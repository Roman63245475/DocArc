<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="360.0" prefWidth="360.0" spacing="12.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.docarc.gui.AssignProfileToUserController">
   <children>
      <Label styleClass="panel-title" text="Assign profile" />
      <Label fx:id="profileNameLabel" text="Profile" />
      <Label text="Users who can receive this profile (regular users without this profile yet):" wrapText="true" />
      <ListView fx:id="eligibleUsersList" prefHeight="200.0" prefWidth="320.0" VBox.vgrow="ALWAYS" />
      <Label fx:id="errorLabel" managed="false" text="Error" visible="false" wrapText="true" />
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button fx:id="assignButton" mnemonicParsing="false" onAction="#onAssign" text="Assign" />
            <Button mnemonicParsing="false" onAction="#onCancel" text="Cancel" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
   </padding>
</VBox>
