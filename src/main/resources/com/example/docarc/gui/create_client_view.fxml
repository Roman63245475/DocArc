<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" minHeight="-Infinity" minWidth="-Infinity" spacing="10.0" stylesheets="@css/user-styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.docarc.gui.CreateClientController">
   <children>
      <Label styleClass="h1" text="Create a new Client">
         <VBox.margin>
            <Insets top="25.0" />
         </VBox.margin>
      </Label>
      <VBox alignment="CENTER" prefWidth="433.0" spacing="5.0">
         <children>
            <HBox alignment="CENTER" spacing="5.0" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets />
               </VBox.margin>
               <children>
                  <Label minWidth="-Infinity" prefWidth="45.0" text="Name:" />
                  <TextField fx:id="nameField" prefHeight="21.0" prefWidth="267.0" />
               </children>
            </HBox>
            <HBox alignment="CENTER" spacing="5.0" VBox.vgrow="ALWAYS">
               <children>
                  <Label text="Country:" />
                  <TextField fx:id="countryField" prefHeight="21.0" prefWidth="267.0" />
               </children>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </HBox>
            <HBox alignment="CENTER" spacing="5.0" VBox.vgrow="ALWAYS">
               <children>
                  <Label minWidth="-Infinity" prefWidth="45.0" text="City:" />
                  <TextField fx:id="cityField" prefHeight="21.0" prefWidth="267.0" />
               </children>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
      <HBox alignment="CENTER_RIGHT" layoutX="30.0" layoutY="179.0" prefHeight="33.0" prefWidth="346.0" spacing="10.0">
         <children>
            <Button mnemonicParsing="false" onAction="#onCancel" prefHeight="28.0" prefWidth="49.0" text="Cancel" />
            <Button mnemonicParsing="false" onAction="#onSave" prefHeight="28.0" prefWidth="49.0" text="Save" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
</VBox>
