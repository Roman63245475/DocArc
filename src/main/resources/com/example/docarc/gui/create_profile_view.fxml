<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="283.0" prefWidth="270.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.docarc.gui.CreateProfileController">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="56.0" prefWidth="270.0">
            <VBox.margin>
                <Insets />
            </VBox.margin>
            <children>
                <Label text="Greyscale">
                    <HBox.margin>
                        <Insets left="25.0" />
                    </HBox.margin>
                </Label>
                <CheckBox fx:id="grayscaleCheckbox" mnemonicParsing="false">
                    <HBox.margin>
                        <Insets left="15.0" />
                    </HBox.margin>
                </CheckBox>
            </children>
        </HBox>
        <HBox alignment="CENTER_LEFT" prefHeight="34.0" prefWidth="600.0">
            <children>
                <Label text="Rotation" />
                <Slider fx:id="rotationSlider" max="360.0" min="-360.0">
                    <HBox.margin>
                        <Insets left="15.0" />
                    </HBox.margin>
                </Slider>
            </children>
            <VBox.margin>
                <Insets left="25.0" />
            </VBox.margin>
        </HBox>
        <HBox alignment="CENTER_LEFT" prefHeight="45.0" prefWidth="600.0">
            <children>
                <Label text="Contrast" />
                <Slider fx:id="contrastSlider" max="1.0" min="-1.0">
                    <HBox.margin>
                        <Insets left="15.0" />
                    </HBox.margin>
                </Slider>
            </children>
            <VBox.margin>
                <Insets left="25.0" />
            </VBox.margin>
        </HBox>
        <HBox alignment="CENTER_LEFT" prefHeight="45.0" prefWidth="600.0">
            <children>
                <Label text="Brightness" />
                <Slider fx:id="brightnessSlider" max="1.0" min="-1.0">
                    <HBox.margin>
                        <Insets left="15.0" />
                    </HBox.margin>
                </Slider>
            </children>
            <VBox.margin>
                <Insets left="25.0" />
            </VBox.margin>
        </HBox>
        <HBox alignment="CENTER_LEFT" prefHeight="45.0" prefWidth="600.0">
            <children>
                <Label text="Name" />
                <TextField fx:id="nameField">
                    <HBox.margin>
                        <Insets left="20.0" />
                    </HBox.margin>
                </TextField>
            </children>
            <VBox.margin>
                <Insets left="25.0" />
            </VBox.margin>
        </HBox>
      <HBox alignment="CENTER" prefHeight="12.0" prefWidth="270.0">
         <children>
            <Label fx:id="errorLabel" opacity="0.0" text="errorLabel" />
         </children>
      </HBox>
      <HBox prefHeight="35.0" prefWidth="270.0" spacing="50.0">
         <children>
            <Button mnemonicParsing="false" onAction="#onCancel" text="Cancel">
               <HBox.margin>
                  <Insets left="50.0" />
               </HBox.margin>
            </Button>
              <Button mnemonicParsing="false" onAction="#onSave" text="Save" />
         </children>
      </HBox>
    </children>
</VBox>
