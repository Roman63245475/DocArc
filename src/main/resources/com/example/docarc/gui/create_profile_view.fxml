<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="290.0" spacing="10.0" stylesheets="@css/user-styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.docarc.gui.CreateProfileController">
    <children>
      <Label styleClass="h2" text="Profile Creation" />
      <VBox alignment="CENTER" prefWidth="100.0" spacing="15.0">
         <children>
              <HBox alignment="CENTER" prefWidth="270.0" spacing="10.0">
                  <VBox.margin>
                      <Insets />
                  </VBox.margin>
                  <children>
                      <Label minWidth="-Infinity" text="Greyscale:">
                          <HBox.margin>
                              <Insets />
                          </HBox.margin>
                      </Label>
                      <CheckBox fx:id="grayscaleCheckbox" mnemonicParsing="false">
                          <HBox.margin>
                              <Insets />
                          </HBox.margin>
                      </CheckBox>
                  <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                  </children>
              </HBox>
              <HBox alignment="CENTER" prefWidth="600.0" spacing="10.0">
                  <children>
                      <Label minWidth="-Infinity" text="Contrast:" />
                      <Slider fx:id="contrastSlider" blockIncrement="0.1" minWidth="-Infinity">
                          <HBox.margin>
                              <Insets />
                          </HBox.margin>
                      </Slider>
                  <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                  <Label fx:id="contrastLabel" minWidth="-Infinity" text="0" />
                  </children>
                  <VBox.margin>
                      <Insets />
                  </VBox.margin>
              </HBox>
              <HBox alignment="CENTER" prefWidth="600.0" spacing="10.0">
                  <children>
                      <Label minWidth="-Infinity" text="Brightness" />
                      <Slider fx:id="brightnessSlider" blockIncrement="0.1" minWidth="-Infinity">
                          <HBox.margin>
                              <Insets />
                          </HBox.margin>
                      </Slider>
                  <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                  <Label fx:id="brightnessLabel" minWidth="-Infinity" text="0" />
                  </children>
                  <VBox.margin>
                      <Insets />
                  </VBox.margin>
              </HBox>
              <HBox alignment="CENTER" prefWidth="600.0" spacing="10.0">
                  <children>
                      <Label minWidth="-Infinity" text="Name:" />
                      <TextField fx:id="nameField" minWidth="-Infinity">
                          <HBox.margin>
                              <Insets />
                          </HBox.margin>
                      </TextField>
                  <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                  </children>
                  <VBox.margin>
                      <Insets />
                  </VBox.margin>
              </HBox>
            <Label fx:id="errorLabel" />
         </children>
      </VBox>
      <HBox alignment="CENTER_RIGHT" prefHeight="35.0" prefWidth="270.0" spacing="10.0">
         <children>
            <ToggleButton minWidth="-Infinity" mnemonicParsing="false" text="Page Preview" />
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Button minWidth="-Infinity" mnemonicParsing="false" onAction="#onCancel" prefHeight="28.0" prefWidth="49.0" text="Cancel">
               <HBox.margin>
                  <Insets />
               </HBox.margin>
            </Button>
              <Button minWidth="-Infinity" mnemonicParsing="false" onAction="#onSave" prefHeight="28.0" prefWidth="44.0" text="Save" />
         </children>
      </HBox>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0" VBox.vgrow="ALWAYS">
         <children>
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="h3" text="Original" />
                   <VBox fx:id="imageContainer" alignment="CENTER" minHeight="0.0" minWidth="0.0" prefHeight="300.0" prefWidth="123.0" VBox.vgrow="ALWAYS">
                     <children>
                        <ImageView fitHeight="${imageContainer.height}" fitWidth="${imageContainer.width}" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/page.png" />
                           </image>
                           <viewport>
                              <Rectangle2D />
                           </viewport>
                        </ImageView>
                     </children>
                  </VBox>
               </children>
            </VBox>
            <Label minWidth="-Infinity" styleClass="h1" text="-&gt;" />
            <VBox alignment="CENTER" layoutX="10.0" layoutY="10.0" prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="h3" text="Post" />
                  <VBox alignment="CENTER" minHeight="0.0" minWidth="0.0" prefHeight="300.0" prefWidth="123.0" VBox.vgrow="ALWAYS">
                     <children>
                        <ImageView fx:id="postImage" fitHeight="${imageContainer.height}" fitWidth="${imageContainer.width}" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/page.png" />
                           </image>
                        </ImageView>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </HBox>
    </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</VBox>
