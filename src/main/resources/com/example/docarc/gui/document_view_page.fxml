<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="570.0" prefWidth="868.0" stylesheets="@css/user-styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.docarc.gui.DocumentViewController">
   <children>
      <HBox alignment="CENTER_LEFT" prefWidth="600.0" spacing="10.0" styleClass="title-bar">
         <children>
            <ImageView fitHeight="28.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@images/LogoBlue_Logoicon.png" />
               </image></ImageView>
            <Region prefHeight="28.0" prefWidth="666.0" HBox.hgrow="ALWAYS" />
            <Label fx:id="userLabel" text="Hello user" textFill="WHITE" />
            <Button fx:id="logOutButton" mnemonicParsing="false" onAction="#logOut" text="Log out" />
         </children>
         <padding>
            <Insets right="10.0" />
         </padding></HBox>
      <SplitPane dividerPositions="0.3894453004622496" prefHeight="160.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
        <items>
            <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0">
               <children>
                  <HBox alignment="CENTER" prefWidth="313.0" spacing="5.0">
                     <children>
                        <Region id="folder-icon" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="15.0" prefWidth="18.0" styleClass="icon" />
                        <Label alignment="CENTER" prefHeight="28.0" prefWidth="84.0" styleClass="h3" text="List of Files" textAlignment="CENTER" />
                     </children>
                  </HBox>
                  <ListView fx:id="listOfFiles" prefHeight="267.0" prefWidth="228.0" styleClass="field" VBox.vgrow="ALWAYS" />
                  <HBox alignment="CENTER" prefHeight="30.0" prefWidth="294.0">
                     <children>
                        <Button layoutX="10.0" layoutY="10.0" maxWidth="Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#onCancel" prefHeight="17.0" prefWidth="109.0" text="Cancel">
                           <padding>
                              <Insets bottom="4.0" left="9.0" right="9.0" top="4.0" />
                           </padding>
                        </Button>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button maxWidth="Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#saveDocument" prefHeight="17.0" prefWidth="109.0" text="Save">
                           <padding>
                              <Insets bottom="4.0" left="9.0" right="9.0" top="4.0" />
                           </padding>
                        </Button>
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding></VBox>
            <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0">
               <children>
                  <HBox alignment="CENTER" prefWidth="200.0">
                     <children>
                        <Label minHeight="28.0" styleClass="h3" text="Page Viewer" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0" VBox.vgrow="ALWAYS">
                     <children>
                        <Button contentDisplay="GRAPHIC_ONLY" maxHeight="1.7976931348623157E308" minWidth="-Infinity" mnemonicParsing="false" onAction="#onRotateLeft" prefHeight="95.0" prefWidth="42.0" VBox.vgrow="ALWAYS">
                           <graphic>
                              <Region id="arrow-left-icon" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="25.0" prefWidth="25.0" style="-fx-background-color: #FFFFFF;" styleClass="icon" />
                           </graphic>
                           <padding>
                              <Insets bottom="2.0" top="2.0" />
                           </padding>
                           <HBox.margin>
                              <Insets bottom="100.0" top="100.0" />
                           </HBox.margin></Button>
                        <VBox fx:id="imageContainer" alignment="CENTER" minHeight="-Infinity" minWidth="-Infinity" prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
                           <children>
                              <ImageView fx:id="pageView" fitHeight="${imageContainer.height}" fitWidth="${imageContainer.width}" pickOnBounds="true" preserveRatio="true" />
                           </children>
                        </VBox>
                        <Button contentDisplay="GRAPHIC_ONLY" layoutX="10.0" layoutY="123.0" maxHeight="1.7976931348623157E308" minWidth="-Infinity" mnemonicParsing="false" onAction="#onRotateRight" prefHeight="95.0" prefWidth="42.0" VBox.vgrow="ALWAYS">
                           <graphic>
                              <Region id="arrow-right-icon" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="25.0" prefWidth="25.0" style="-fx-background-color: #FFFFFF;" styleClass="icon" />
                           </graphic>
                           <padding>
                              <Insets bottom="2.0" top="2.0" />
                           </padding>
                           <HBox.margin>
                              <Insets bottom="100.0" top="100.0" />
                           </HBox.margin>
                        </Button>
                     </children>
                  </HBox>
                  <StackPane prefHeight="37.0" prefWidth="524.0">
                     <children>
                        <Button fx:id="btnExportId" disable="true" mnemonicParsing="false" onAction="#btnExportOnClick" opacity="0.0" prefHeight="27.0" prefWidth="134.0" text="Export" />
                        <HBox fx:id="hboxId" alignment="CENTER" prefHeight="100.0" prefWidth="200.0" visible="false">
                           <children>
                              <Button mnemonicParsing="false" onAction="#btnSinglePageOnClick" prefHeight="27.0" prefWidth="81.0" text="Singlepage">
                                 <HBox.margin>
                                    <Insets right="25.0" />
                                 </HBox.margin>
                              </Button>
                              <Button mnemonicParsing="false" onAction="#btnMultipageOnClick" prefHeight="27.0" prefWidth="89.0" text="Multi page" />
                           </children>
                        </HBox>
                     </children>
                  </StackPane>
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding></VBox>
        </items>
      </SplitPane>
   </children>
</VBox>
