<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="610.0" prefWidth="844.0" spacing="20" style="-fx-background-color: #f5f7fb;" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.docarc.gui.MainUserController">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>


    <!-- Заголовок -->
    <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Adding Documents" />

    <Label style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;" text="Select box and add new documents via api" />
   <Button mnemonicParsing="false" onAction="#createBox" text="Create new Box" />
   <ScrollPane fx:id="boxesArea" prefHeight="320.0" prefWidth="783.0">
      <content>
         <VBox fx:id="boxCardsArea" prefHeight="321.0" prefWidth="782.0" />
      </content>
   </ScrollPane>

    <!-- Большая кнопка снизу (если нужна для общего действия) -->
    <Button maxWidth="300" onAction="#loadAllDocuments" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 25;" text="Upload document to the each box via API" />
</VBox>
