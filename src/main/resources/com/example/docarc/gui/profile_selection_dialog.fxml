<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<DialogPane stylesheets="@css/user-styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.docarc.gui.ProfileSelectionController">
    <content>
        <VBox alignment="CENTER" spacing="15">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>
            <Label styleClass="h3" text="Select Profile for Document Processing:" />
            <ComboBox fx:id="profileComboBox" prefWidth="250.0" promptText="Choose a profile..." styleClass="field" />
        </VBox>
    </content>
    <expandableContent>
        <VBox spacing="10">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10" />
            </padding>
            <Label style="-fx-text-fill: #666; -fx-font-size: 12px;" text="Profile settings will be applied to the scanned document." />
        </VBox>
    </expandableContent>
</DialogPane>
