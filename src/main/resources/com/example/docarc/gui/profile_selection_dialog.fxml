<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<DialogPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.docarc.gui.ProfileSelectionController">
    <content>
        <VBox spacing="15" alignment="CENTER_LEFT">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>
            <Label text="Select Profile for Document Processing:" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            <ComboBox fx:id="profileComboBox" prefWidth="250.0" promptText="Choose a profile..."/>
        </VBox>
    </content>
    <expandableContent>
        <VBox spacing="10">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10" />
            </padding>
            <Label text="Profile settings will be applied to the scanned document." style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
        </VBox>
    </expandableContent>
</DialogPane>
