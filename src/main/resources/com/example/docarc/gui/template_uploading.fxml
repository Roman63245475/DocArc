<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="20" style="-fx-background-color: #f5f7fb;" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.docarc.gui.UploadTemplateCont">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>


    <!-- Заголовок -->
    <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Adding Documents" />

    <Label style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;" text="Select box and add new documents via api" />
   <Button mnemonicParsing="false" onAction="#createBox" text="Create new Box" />

    <!-- Контейнер для трёх Box-ов (горизонтально) -->
    <HBox alignment="CENTER_LEFT" fillHeight="false" spacing="30" VBox.vgrow="ALWAYS">
        <!-- Box A -->
        <VBox fx:id="boxAContainer" prefWidth="280" spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>
            <Label fx:id="boxATitle" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2980b9;">
                <text>Box A - Contracts</text>
            </Label>
            <Label fx:id="boxADocCount" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;">
                <text>
                    24 док.
                </text>
            </Label>
            <Separator />
            <!-- Динамическая область документов для Box A -->
            <VBox fx:id="boxADocumentsArea" spacing="10">
                <!-- СЮДА БУДУТ ДОБАВЛЯТЬСЯ ДОКУМЕНТЫ ИЗ КОДА (ЗАГЛУШКА ДЛЯ ПРИМЕРА) -->
                <VBox style="-fx-border-color: #ecf0f1; -fx-border-radius: 8; -fx-padding: 10;">
                    <Label style="-fx-font-weight: bold;" text="Document 001" />
                    <Label style="-fx-text-fill: #27ae60; -fx-font-size: 12px;" text="5 Files" />
                    <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" text="2026-05-01" />
                </VBox>
                <VBox style="-fx-border-color: #ecf0f1; -fx-border-radius: 8; -fx-padding: 10;">
                    <Label style="-fx-font-weight: bold;" text="Document 002" />
                    <Label style="-fx-text-fill: #27ae60; -fx-font-size: 12px;" text="3 Files" />
                    <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" text="2026-05-02" />
                </VBox>
            </VBox>
            <Button onAction="#loadDocumentsForBox" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 20;" text="Upload document to the box A via API" />
        </VBox>

        <!-- Box B -->
        <VBox fx:id="boxBContainer" prefWidth="280" spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>
            <Label fx:id="boxBTitle" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #16a085;">
                <text>Box B - Bills</text>
            </Label>
            <Label fx:id="boxBDocCount" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;">
                <text>18 doc.</text>
            </Label>
            <Separator />
            <VBox fx:id="boxBDocumentsArea" spacing="10">
                <!-- динамические данные -->
            </VBox>
            <Button onAction="#loadDocumentsForBox" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 20;" text="Upload document to the box B via API" />
        </VBox>

        <!-- Box C -->
        <VBox fx:id="boxCContainer" prefWidth="280" spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>
            <Label fx:id="boxCTitle" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e67e22;">
                <text>Box C - Something Else</text>
            </Label>
            <Label fx:id="boxCDocCount" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;">
                <text>32 doc.</text>
            </Label>
            <Separator />
            <VBox fx:id="boxCDocumentsArea" spacing="10">
                <!-- динамические данные -->
            </VBox>
            <Button onAction="#loadDocumentsForBox" style="-fx-background-color: #f1c40f; -fx-text-fill: #2c3e50; -fx-background-radius: 20;" text="Upload document to the box C via API" />
        </VBox>
    </HBox>

    <!-- Большая кнопка снизу (если нужна для общего действия) -->
    <Button maxWidth="300" onAction="#loadAllDocuments" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 25;" text="Upload document to the each box via API" />
</VBox>
